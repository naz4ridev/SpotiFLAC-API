# Git & Branch settings
APP_REPO_URL=git@github.com:OWNER/REPO.git
APP_BRANCH=main
UPDATER_BRANCH=spotiflac-updater

# Directories used for cloning and state tracking
WORKDIR=/tmp/spotiflacapi-update-workdir
STATE_DIR=/opt/spotiflac-updater/state

# Production API endpoints & thresholds
BASE_URL=https://office.naz4rimusic.com/tools/spotiflacapi
TEST_TRACK_URL=
MIN_AUDIO_BYTES=100000

# Upstream repository settings
SPOTIFLAC_REPO=spotbye/SpotiFLAC
GO_MODULE_PATH=github.com/afkarxyz/SpotiFLAC
UPDATE_MODE=release

# Coolify deployment integration
COOLIFY_REDEPLOY_URL=
COOLIFY_DEPLOY_TIMEOUT_SECONDS=600

# Uptime Kuma Push Monitor URLs
UPTIME_KUMA_UPDATE_PUSH_URL=
UPTIME_KUMA_DAILY_SMOKE_PUSH_URL=

# Git Commit Author Settings (for automatic dependency updates committed to main)
GIT_AUTHOR_NAME=spotiflac-updater
GIT_AUTHOR_EMAIL=spotiflac-updater@naz4rimusic.com
