# Server
BIND_ADDR=127.0.0.1
PORT=8080
BASE_URL=http://127.0.0.1:8080
DOWNLOAD_TTL=2h
HTTP_CLIENT_TIMEOUT=20s
SPOTIFY_METADATA_TIMEOUT=45s
FFMPEG_AUTO_INSTALL=false

# Monochrome discovery and instance endpoints.
MONOCHROME_DISCOVERY_URLS=https://tidal-uptime.geeked.wtf/
MONOCHROME_API_INSTANCES=https://hifi.geeked.wtf,https://eu-central.monochrome.tf,https://us-west.monochrome.tf,https://api.monochrome.tf,https://monochrome-api.samidy.com,https://maus.qqdl.site,https://vogel.qqdl.site,https://katze.qqdl.site,https://hund.qqdl.site,https://tidal.kinoplus.online,https://wolf.qqdl.site
MONOCHROME_STREAMING_INSTANCES=https://hifi.geeked.wtf,https://maus.qqdl.site,https://vogel.qqdl.site,https://katze.qqdl.site,https://hund.qqdl.site,https://wolf.qqdl.site

# Optional overrides for the browser credentials used by the Monochrome fallback chain.
MONOCHROME_TIDAL_CLIENT_ID=txNoH4kkV41MfH25
MONOCHROME_TIDAL_CLIENT_SECRET=dQjy0MinCEvxi1O4UmxvxWnDjt4cgHBPw8ll6nYBk98=

# --- SpotiFLAC Auto-Update & Monitoring Configurations ---

# Base URL of the API in production (used by smoke tests and URL generation)
# If Nginx proxy serves it under a subpath, include the subpath here without trailing slash.
BASE_URL=https://office.naz4rimusic.com/tools/spotiflacapi

# Spotify track URL/ID used for the smoke test download verification
TEST_TRACK_URL=https://open.spotify.com/track/4PTG3Z6ehGkBF3sIqR13Cc

# Upstream repository to monitor for updates
SPOTIFLAC_REPO=spotbye/SpotiFLAC

# Mode to monitor upstream updates: 'release' (fetches latest release tag) or 'commit' (fetches HEAD branch)
UPDATE_MODE=release

# Minimum expected size (in bytes) of the downloaded test file during smoke test
MIN_AUDIO_BYTES=100000

# Deployment method: 'docker-compose', 'systemd', or 'coolify'
DEPLOY_METHOD=docker-compose

# Docker Compose configuration variables
COMPOSE_FILE=docker-compose.yml
COMPOSE_PROJECT_NAME=spotiflacapi
HOST_BIND_IP=127.0.0.1
HOST_PORT=18150
CONTAINER_PORT=8080

# Systemd configuration (only used if DEPLOY_METHOD=systemd)
SERVICE_NAME=spotiflac-api

# Local Coolify webhook URL (only needed if DEPLOY_METHOD=coolify)
COOLIFY_WEBHOOK_URL=

# Optional Uptime Kuma Push Monitor URL to report OK/DOWN status
UPTIME_KUMA_PUSH_URL=

